    array.push(pr_types, "hist")
    array.push(pr_isUp, true)

    array.push(pr_ts, pr_w2_ts)
    array.push(pr_prices, pr_w2_p)
    array.push(pr_names, "W2")
    array.push(pr_ohlc, "L")
    array.push(pr_fibs, "53.6%")
    array.push(pr_types, "hist")
    array.push(pr_isUp, false)

    array.push(pr_ts, pr_w3_ts)
    array.push(pr_prices, pr_w3_p)
    array.push(pr_names, "W3")
    array.push(pr_ohlc, "H")
    array.push(pr_fibs, "331.3%")
    array.push(pr_types, "hist")
    array.push(pr_isUp, true)

    array.push(pr_ts, pr_w4_ts)
    array.push(pr_prices, pr_w4_p)
