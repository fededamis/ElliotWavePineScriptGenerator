                        array.push(allLabels, slbl)
                    else
                        label slbl = label.new(slts, slp, sltxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_up, color=sw3col, textcolor=color.white, size=size.tiny, textalign=text.align_center)
                        array.push(allLabels, slbl)
                    sli += 1

