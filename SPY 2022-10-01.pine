    array.push(pr_ohlc, "L")
    array.push(pr_fibs, "38.2%")
    array.push(pr_types, "proj")
    array.push(pr_isUp, false)

    array.push(pr_ts, pr_wb_ts)
    array.push(pr_prices, pr_wb_p)
    array.push(pr_names, "WB")
    array.push(pr_ohlc, "H")
    array.push(pr_fibs, "50.0%")
    array.push(pr_types, "proj")
    array.push(pr_isUp, true)

    array.push(pr_ts, pr_wc_ts)
    array.push(pr_prices, pr_wc_p)
    array.push(pr_names, "WC")
    array.push(pr_ohlc, "L")
    array.push(pr_fibs, "100.0%")
    array.push(pr_types, "proj")
    array.push(pr_isUp, false)

    // Primary segment colors
    array<color> pr_segColors = array.new<color>()
    array.push(pr_segColors, PR_MOTIVE_UP)   // W0->W1
    array.push(pr_segColors, PR_CORRECTIVE)   // W1->W2
    array.push(pr_segColors, PR_MOTIVE_UP)   // W2->W3
    array.push(pr_segColors, PR_CORRECTIVE)   // W3->W4
    array.push(pr_segColors, PR_MOTIVE_UP)   // W4->W5
    array.push(pr_segColors, PR_CORRECTIVE)   // W5->WA
    array.push(pr_segColors, PR_CORRECTIVE)   // WA->WB
    array.push(pr_segColors, PR_CORRECTIVE)   // WB->WC

    // === BUILD ALTERNATE ARRAYS ===
    array<int> al_ts = array.new<int>()
    array<float> al_prices = array.new<float>()
    array<string> al_names = array.new<string>()
    array<string> al_ohlc = array.new<string>()
    array<string> al_fibs = array.new<string>()
    array<string> al_types = array.new<string>()

    array.push(al_ts, al_w0_ts)
    array.push(al_prices, al_w0_p)
    array.push(al_names, "W0")
    array.push(al_ohlc, "L")
    array.push(al_fibs, "--")
    array.push(al_types, "hist")

    array.push(al_ts, al_w1_ts)
    array.push(al_prices, al_w1_p)
    array.push(al_names, "W1")
    array.push(al_ohlc, "H")
    array.push(al_fibs, "--")
    array.push(al_types, "hist")

    array.push(al_ts, al_w2_ts)
    array.push(al_prices, al_w2_p)
    array.push(al_names, "W2")
    array.push(al_ohlc, "L")
    array.push(al_fibs, "53.6%")
    array.push(al_types, "hist")

    array.push(al_ts, al_w3_ts)
    array.push(al_prices, al_w3_p)
    array.push(al_names, "W3")
    array.push(al_ohlc, "H")
    array.push(al_fibs, "262.8%")
    array.push(al_types, "hist")

    array.push(al_ts, al_w4_ts)
    array.push(al_prices, al_w4_p)
    array.push(al_names, "W4")
    array.push(al_ohlc, "L")
    array.push(al_fibs, "29.7%")
    array.push(al_types, "hist")

    array.push(al_ts, al_w5_ts)
    array.push(al_prices, al_w5_p)
    array.push(al_names, "W5")
    array.push(al_ohlc, "H")
    array.push(al_fibs, "146.7%")
    array.push(al_types, "hist")

    array.push(al_ts, al_wa_ts)
    array.push(al_prices, al_wa_p)
    array.push(al_names, "WA")
    array.push(al_ohlc, "L")
    array.push(al_fibs, "49.6%")
    array.push(al_types, "hist")

    array.push(al_ts, al_wb_ts)
    array.push(al_prices, al_wb_p)
    array.push(al_names, "WB")
    array.push(al_ohlc, "H")
    array.push(al_fibs, "164.4%")
    array.push(al_types, "hist")

    array.push(al_ts, al_wc_ts)
    array.push(al_prices, al_wc_p)
    array.push(al_names, "WC")
    array.push(al_ohlc, "L")
    array.push(al_fibs, "100.0%")
    array.push(al_types, "proj")

    // Alternate segment colors
    array<color> al_segColors = array.new<color>()
    array.push(al_segColors, AL_MOTIVE_UP)    // W0->W1
    array.push(al_segColors, AL_CORRECTIVE)    // W1->W2
    array.push(al_segColors, AL_MOTIVE_UP)    // W2->W3
    array.push(al_segColors, AL_CORRECTIVE)    // W3->W4
    array.push(al_segColors, AL_MOTIVE_UP)    // W4->W5
    array.push(al_segColors, AL_CORRECTIVE)    // W5->WA
    array.push(al_segColors, AL_CORRECTIVE)    // WA->WB
    array.push(al_segColors, AL_CORRECTIVE)    // WB->WC

    // === Y-OFFSET COLLISION AVOIDANCE ===
    array<float> pr_yoffs = array.new<float>(array.size(pr_prices), 0.0)
    array<float> al_yoffs = array.new<float>(array.size(al_prices), 0.0)

    int pr_sz = array.size(pr_prices)
    int idx1 = 0
    while idx1 < pr_sz
        int idx2 = idx1 + 1
        while idx2 < pr_sz
            // array size checked before access
            float p1 = array.size(pr_prices) > idx1 ? array.get(pr_prices, idx1) : 0.0
            float p2 = array.size(pr_prices) > idx2 ? array.get(pr_prices, idx2) : 0.0
            int t1 = array.size(pr_ts) > idx1 ? array.get(pr_ts, idx1) : 0
            int t2 = array.size(pr_ts) > idx2 ? array.get(pr_ts, idx2) : 0
            if math.abs(p1 - p2) < priceRange * 0.05 and math.abs(t1 - t2) < 8 * 7 * 86400000
                // array size checked before access
                string ohlc2 = array.size(pr_ohlc) > idx2 ? array.get(pr_ohlc, idx2) : "H"
                float offAmt = priceRange * 0.03
                if ohlc2 == "H"
                    array.set(pr_yoffs, idx2, offAmt)
                else
                    array.set(pr_yoffs, idx2, -offAmt)
            idx2 += 1
        idx1 += 1

    int al_sz = array.size(al_prices)
    int aidx1 = 0
    while aidx1 < al_sz
        int aidx2 = aidx1 + 1
        while aidx2 < al_sz
            // array size checked before access
            float ap1 = array.size(al_prices) > aidx1 ? array.get(al_prices, aidx1) : 0.0
            float ap2 = array.size(al_prices) > aidx2 ? array.get(al_prices, aidx2) : 0.0
            int at1 = array.size(al_ts) > aidx1 ? array.get(al_ts, aidx1) : 0
            int at2 = array.size(al_ts) > aidx2 ? array.get(al_ts, aidx2) : 0
            if math.abs(ap1 - ap2) < priceRange * 0.05 and math.abs(at1 - at2) < 8 * 7 * 86400000
                // array size checked before access
                string aohlc2 = array.size(al_ohlc) > aidx2 ? array.get(al_ohlc, aidx2) : "H"
                float aoffAmt = priceRange * 0.03
                if aohlc2 == "H"
                    array.set(al_yoffs, aidx2, aoffAmt)
                else
                    array.set(al_yoffs, aidx2, -aoffAmt)
            aidx2 += 1
        aidx1 += 1

    // === DETERMINE RENDERING FLAGS ===
    bool drawPrimary = showCount == "Primary Only" or showCount == "Both"
    bool drawAlternate = showCount == "Alternate Only" or showCount == "Both"
    bool altOnly = showCount == "Alternate Only"

    // === DRAW PRIMARY COUNT ===
    if drawPrimary
        int i = 1
        while i < array.size(pr_ts)
            // array size checked before access
            int ts1 = array.size(pr_ts) > (i - 1) ? array.get(pr_ts, i - 1) : 0
            int ts2 = array.size(pr_ts) > i ? array.get(pr_ts, i) : 0
            float p1 = array.size(pr_prices) > (i - 1) ? array.get(pr_prices, i - 1) : 0.0
            float p2 = array.size(pr_prices) > i ? array.get(pr_prices, i) : 0.0
            string type1 = array.size(pr_types) > (i - 1) ? array.get(pr_types, i - 1) : "hist"
            string type2 = array.size(pr_types) > i ? array.get(pr_types, i) : "hist"
            color segCol = array.size(pr_segColors) > (i - 1) ? array.get(pr_segColors, i - 1) : PR_MOTIVE_UP

            bool isHist = type1 == "hist" and type2 == "hist"
            bool isProj = type1 == "proj" or type2 == "proj"

            bool shouldDraw = true
            if isProj and not showProj
                shouldDraw := false

            if shouldDraw
                string lstyle = isHist ? STYLE_SOLID : STYLE_DOTTED
                line seg = line.new(ts1, p1, ts2, p2, xloc=xloc.bar_time, color=segCol, style=lstyle, width=2)
                array.push(allLines, seg)
            i += 1

        // Primary labels
        if showLabels
            int li = 0
            while li < array.size(pr_ts)
                // array size checked before access
                string ltype = array.size(pr_types) > li ? array.get(pr_types, li) : "hist"
                bool isProj2 = ltype == "proj"
                if isProj2 and not showProj
                    li += 1
                    continue

                int lts = array.size(pr_ts) > li ? array.get(pr_ts, li) : 0
                float lprice = array.size(pr_prices) > li ? array.get(pr_prices, li) : 0.0
                string lname = array.size(pr_names) > li ? array.get(pr_names, li) : ""
                string lohlc = array.size(pr_ohlc) > li ? array.get(pr_ohlc, li) : "H"
                string lfib = array.size(pr_fibs) > li ? array.get(pr_fibs, li) : "--"
                float lyoff = array.size(pr_yoffs) > li ? array.get(pr_yoffs, li) : 0.0

                string ltxt = makePivotText(lname, lprice, lfib, false, isProj2)
                float labelY = lprice + lyoff

                // Determine label color based on segment
                color lblCol = PR_MOTIVE_UP
                if li > 0
                    // array size checked before access
                    lblCol := array.size(pr_segColors) > (li - 1) ? array.get(pr_segColors, li - 1) : PR_MOTIVE_UP

                if lohlc == "H"
                    if lprice > (li > 0 and array.size(pr_prices) > (li - 1) ? array.get(pr_prices, li - 1) : 0.0)
                        label lbl = label.new(lts, labelY, ltxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_down, color=lblCol, textcolor=color.white, size=size.small, textalign=text.align_center)
                        array.push(allLabels, lbl)
                    else
                        label lbl = label.new(lts, labelY, ltxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_up, color=lblCol, textcolor=color.white, size=size.small, textalign=text.align_center)
                        array.push(allLabels, lbl)
                else
                    label lbl = label.new(lts, labelY, ltxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_up, color=lblCol, textcolor=color.white, size=size.small, textalign=text.align_center)
                    array.push(allLabels, lbl)
                li += 1

    // === DRAW ALTERNATE COUNT ===
    if drawAlternate
        int i = 1
        while i < array.size(al_ts)
            // array size checked before access
            int ts1 = array.size(al_ts) > (i - 1) ? array.get(al_ts, i - 1) : 0
            int ts2 = array.size(al_ts) > i ? array.get(al_ts, i) : 0
            float p1 = array.size(al_prices) > (i - 1) ? array.get(al_prices, i - 1) : 0.0
            float p2 = array.size(al_prices) > i ? array.get(al_prices, i) : 0.0
            string type1 = array.size(al_types) > (i - 1) ? array.get(al_types, i - 1) : "hist"
            string type2 = array.size(al_types) > i ? array.get(al_types, i) : "hist"
            color segCol = array.size(al_segColors) > (i - 1) ? array.get(al_segColors, i - 1) : AL_MOTIVE_UP

            bool isHist = type1 == "hist" and type2 == "hist"
            bool isProj = type1 == "proj" or type2 == "proj"

            bool shouldDraw = true
            if isProj and not showProj
                shouldDraw := false

            if shouldDraw
                string lstyle = STYLE_DASHED
                if isProj
                    lstyle := STYLE_DOTTED
                if altOnly and isHist
                    lstyle := STYLE_SOLID
                int alTransp = altOnly ? 0 : 50
                color alSegCol = color.new(segCol, alTransp)
                line seg = line.new(ts1, p1, ts2, p2, xloc=xloc.bar_time, color=alSegCol, style=lstyle, width=2)
                array.push(allLines, seg)
            i += 1

        // Alternate labels
        if showLabels
            int li = 0
            while li < array.size(al_ts)
                // array size checked before access
                string ltype = array.size(al_types) > li ? array.get(al_types, li) : "hist"
                bool isProj2 = ltype == "proj"
                if isProj2 and not showProj
                    li += 1
                    continue

                int lts = array.size(al_ts) > li ? array.get(al_ts, li) : 0
                float lprice = array.size(al_prices) > li ? array.get(al_prices, li) : 0.0
                string lname = array.size(al_names) > li ? array.get(al_names, li) : ""
                string lohlc = array.size(al_ohlc) > li ? array.get(al_ohlc, li) : "H"
                string lfib = array.size(al_fibs) > li ? array.get(al_fibs, li) : "--"
                float lyoff = array.size(al_yoffs) > li ? array.get(al_yoffs, li) : 0.0

                string ltxt = makePivotText(lname, lprice, lfib, true, isProj2)
                float labelY = lprice + lyoff

                color lblCol = AL_MOTIVE_UP
                if li > 0
                    // array size checked before access
                    lblCol := array.size(al_segColors) > (li - 1) ? array.get(al_segColors, li - 1) : AL_MOTIVE_UP
                color lblColTransp = altOnly ? lblCol : color.new(lblCol, 50)

                if lohlc == "H"
                    label lbl = label.new(lts, labelY, ltxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_down, color=lblColTransp, textcolor=color.white, size=size.small, textalign=text.align_center)
                    array.push(allLabels, lbl)
                else
                    label lbl = label.new(lts, labelY, ltxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_up, color=lblColTransp, textcolor=color.white, size=size.small, textalign=text.align_center)
                    array.push(allLabels, lbl)
                li += 1

    // === DRAW PRIMARY SUBWAVES ===
    if showSubwaves and drawPrimary
        color sw3col = color.new(PR_MOTIVE_UP, 55)
        color sw4col = color.new(PR_CORRECTIVE, 55)
        color sw5col = color.new(PR_MOTIVE_UP, 55)

        // W3 subwaves: W2 end -> sw1 -> sw2 -> sw3 -> sw4 -> sw5(=W3)
