//@version=6
indicator("SPY Elliott Wave Count", overlay=true, max_lines_count=500, max_labels_count=500)

// === INPUTS ===
string showCount = input.string("Primary Only", "Show Count", options=["Primary Only", "Both", "Alternate Only"])
bool showInval = input.bool(true, "Show Invalidation Levels")
bool showTargets = input.bool(true, "Show Targets")
bool showLegend = input.bool(true, "Show Legend")
string legendPos = input.string("Bottom Right", "Legend Position", options=["Top Right", "Bottom Right", "Top Left", "Bottom Left"])
bool showProj = input.bool(true, "Show Projections")
bool showLabels = input.bool(true, "Show Labels")
bool showSubwaves = input.bool(true, "Show Subwaves")

// === STYLE CONSTANTS AS STRINGS ===
string STYLE_SOLID = line.style_solid
string STYLE_DASHED = line.style_dashed
string STYLE_DOTTED = line.style_dotted

// === COLOR CONSTANTS ===
color PR_MOTIVE_UP = color.aqua
color PR_MOTIVE_DN = color.fuchsia
color PR_CORRECTIVE = color.orange
color PR_INVAL_COL = color.red
color PR_TARGET_COL = color.lime

color AL_MOTIVE_UP = color.rgb(85, 153, 170)
color AL_MOTIVE_DN = color.rgb(170, 85, 170)
color AL_CORRECTIVE = color.rgb(170, 119, 51)
color AL_INVAL_COL = color.rgb(204, 68, 68)
color AL_TARGET_COL = color.rgb(68, 136, 68)

// === ARRAYS FOR CLEANUP ===
var array<line> allLines = array.new<line>()
var array<label> allLabels = array.new<label>()

// === HELPER FUNCTIONS (top-level, no type annotations on params) ===

getSegColor(isUp, isPrimary) =>
    color result = na
    if isPrimary
        result := isUp ? PR_MOTIVE_UP : PR_CORRECTIVE
    else
        result := isUp ? AL_MOTIVE_UP : AL_CORRECTIVE
    result

getPrLineStyle(isHist, isPrimary, isAlternateOnly) =>
    string result = STYLE_SOLID
    if not isHist
        result := STYLE_DOTTED
    else
        if isPrimary
            result := STYLE_SOLID
        else
            if isAlternateOnly
                result := STYLE_SOLID
            else
                result := STYLE_DASHED
    result

makePivotText(waveName, price, fib, isAlt, isProj) =>
    string line1 = ""
    if isAlt and isProj
        line1 := "(A)(proj) " + waveName
    else if isAlt
        line1 := "(A) " + waveName
    else if isProj
        line1 := "(proj) " + waveName
    else
        line1 := waveName
    string line2 = "$" + str.tostring(price, "#.##")
    string line3 = fib != "--" ? "Fib:" + fib : ""
    string result = line3 != "" ? line1 + "\n" + line2 + "\n" + line3 : line1 + "\n" + line2
    result

checkCollision(yoffs, idx, prices, timestamps, range_size, totalPivots) =>
    float off = 0.0
    float thresh_price = range_size * 0.05
    int thresh_time = 8 * 7 * 86400000
    int i = 0
    while i < idx and i < totalPivots
        // array size checked before access
        float pi = array.size(prices) > i ? array.get(prices, i) : 0.0
        int ti = array.size(timestamps) > i ? array.get(timestamps, i) : 0
        float pj = array.size(prices) > idx ? array.get(prices, idx) : 0.0
        int tj = array.size(timestamps) > idx ? array.get(timestamps, idx) : 0
        if math.abs(pi - pj) < thresh_price and math.abs(ti - tj) < thresh_time
            off := range_size * 0.03
            break
        i += 1
    off

