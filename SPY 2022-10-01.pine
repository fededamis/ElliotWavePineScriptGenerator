                    string aslohlc = array.get(aswB_ohlc, asli)
                    string asltxt = makePivotText(array.get(aswB_names, asli), array.get(aswB_p, asli), array.get(aswB_fibs, asli), true, false)
                    if aslohlc == "H"
                        label aslbl = label.new(array.get(aswB_ts, asli), array.get(aswB_p, asli), asltxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_down, color=color.new(alswBcol, 50), textcolor=color.white, size=size.tiny, textalign=text.align_center)
                        array.push(allLabels, aslbl)
                    else
                        label aslbl = label.new(array.get(aswB_ts, asli), array.get(aswB_p, asli), asltxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_up, color=color.new(alswBcol, 50), textcolor=color.white, size=size.tiny, textalign=text.align_center)
                        array.push(allLabels, aslbl)
                    asli += 1

    // === INVALIDATION LEVELS ===
    if showInval
        if drawPrimary
            // Primary invalidation: horizontal from W4 date to WC proj date
            line prInvalLine = line.new(pr_w4_ts, pr_inval, pr_wc_ts, pr_inval, xloc=xloc.bar_time, color=PR_INVAL_COL, style=STYLE_DASHED, width=1)
            array.push(allLines, prInvalLine)
            if showLabels
                string prInvalTxt = "Primary Inval\n$" + str.tostring(pr_inval, "#.##")
                label prInvalLbl = label.new(pr_w4_ts, pr_inval, prInvalTxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_up, color=PR_INVAL_COL, textcolor=color.white, size=size.small, textalign=text.align_center)
                array.push(allLabels, prInvalLbl)

        if drawAlternate
            // Alternate invalidation: horizontal from WB date to WC proj date
            line alInvalLine = line.new(al_wb_ts, al_inval, al_wc_ts, al_inval, xloc=xloc.bar_time, color=AL_INVAL_COL, style=STYLE_DASHED, width=1)
            array.push(allLines, alInvalLine)
            if showLabels
                string alInvalTxt = "Alt Inval\n$" + str.tostring(al_inval, "#.##")
                label alInvalLbl = label.new(al_wb_ts, al_inval, alInvalTxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_down, color=AL_INVAL_COL, textcolor=color.white, size=size.small, textalign=text.align_center)
                array.push(allLabels, alInvalLbl)

    // === TARGET LEVELS ===
    if showTargets
        if drawPrimary
            // Primary target: from W5 to WC
            line prTargetLine = line.new(pr_w5_ts, pr_target, pr_wc_ts, pr_target, xloc=xloc.bar_time, color=PR_TARGET_COL, style=STYLE_DOTTED, width=1)
            array.push(allLines, prTargetLine)
            if showLabels
                string prTargetTxt = "Primary Target\n$" + str.tostring(pr_target, "#.##") + "\nFib " + pr_target_fib
                label prTargetLbl = label.new(pr_wc_ts, pr_target, prTargetTxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_up, color=PR_TARGET_COL, textcolor=color.black, size=size.small, textalign=text.align_center)
                array.push(allLabels, prTargetLbl)

        if drawAlternate
            // Alternate target: from WB to WC
            line alTargetLine = line.new(al_wb_ts, al_target, al_wc_ts, al_target, xloc=xloc.bar_time, color=AL_TARGET_COL, style=STYLE_DOTTED, width=1)
            array.push(allLines, alTargetLine)
            if showLabels
                string alTargetTxt = "Alt Target\n$" + str.tostring(al_target, "#.##") + "\nFib " + al_target_fib
                label alTargetLbl = label.new(al_wc_ts, al_target, alTargetTxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_up, color=AL_TARGET_COL, textcolor=color.white, size=size.small, textalign=text.align_center)
                array.push(allLabels, alTargetLbl)

    // === LEGEND ===
    if showLegend
        int firstPivotTs = pr_w0_ts
        float highestPrice = priceHigh
        float lowestPrice = priceLow
        float legendStep = priceRange * 0.04

        int leg_x = todayTime + 86400000 * 7
        float leg_base = lowestPrice

        if legendPos == "Top Right"
            leg_x := todayTime + 86400000 * 7
            leg_base := highestPrice
        else if legendPos == "Bottom Right"
            leg_x := todayTime + 86400000 * 7
            leg_base := lowestPrice
        else if legendPos == "Top Left"
            leg_x := firstPivotTs - 86400000 * 30
            leg_base := highestPrice
        else if legendPos == "Bottom Left"
            leg_x := firstPivotTs - 86400000 * 30
            leg_base := lowestPrice

        if drawPrimary
            string prLegTxt = "Primary Count (55%)"
            label prLegLbl = label.new(leg_x, leg_base, prLegTxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_left, color=PR_MOTIVE_UP, textcolor=color.white, size=size.small, textalign=text.align_center)
            array.push(allLabels, prLegLbl)

        if drawAlternate
            float altLegY = leg_base - legendStep
            string alLegTxt = "Alternate Count (45%)"
            label alLegLbl = label.new(leg_x, altLegY, alLegTxt, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_left, color=AL_MOTIVE_UP, textcolor=color.white, size=size.small, textalign=text.align_center)
            array.push(allLabels, alLegLbl)
