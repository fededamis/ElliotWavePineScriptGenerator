// All drawing objects use xloc.bar_time + fixed float prices for scale/zoom stability
if barstate.islast
    // Clean up old drawings
    while array.size(allLines) > 0
        line.delete(array.pop(allLines))
    while array.size(allLabels) > 0
        label.delete(array.pop(allLabels))

    int todayTime = time
    float priceHigh = 697.84
    float priceLow = 348.11
    float priceRange = priceHigh - priceLow

    // === BUILD PRIMARY ARRAYS ===
    array<int> pr_ts = array.new<int>()
    array<float> pr_prices = array.new<float>()
    array<string> pr_names = array.new<string>()
    array<string> pr_ohlc = array.new<string>()
    array<string> pr_fibs = array.new<string>()
    array<string> pr_types = array.new<string>()
    array<bool> pr_isUp = array.new<bool>()

    array.push(pr_ts, pr_w0_ts)
    array.push(pr_prices, pr_w0_p)
    array.push(pr_names, "W0")
    array.push(pr_ohlc, "L")
